[init]
	defaultBranch = main
[branch]
	sort = -committerdate # 看 branch 時最新動過的分支排在最上面
[tag]
	sort = version:refname
[column]
    ui = auto
[color]
	status = always
	ui = true
[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
	autocrlf = input
	editor = vim
	ignorecase = false
	commitGraph = true
	pager = delta

[interactive]
    diffFilter = delta --color-only
[delta]
	# https://dandavison.github.io/delta/introduction.html
    navigate = true    # use n and N to move between diff sections
    # delta detects terminal colors automatically; set one of these to disable auto-detection
    dark = true
    # light = true
	true-color = always

	side-by-side = true
	line-numbers = true

	hyperlinks = true
	hyperlinks-file-link-format = "vscode://file/{path}:{line}"
    # hyperlinks-file-link-format = "idea://open?file={path}&line={line}"
    # hyperlinks-file-link-format = "pycharm://open?file={path}&line={line}"

[diff]
	tool = difftastic
[difftool "difftastic"]
    # 指定外部工具執行 difftastic 的指令
    cmd = difft "$LOCAL" "$REMOTE"
[pager]
    # 確保使用 difftool 時不會被 delta 二次攔截處理
    difftool = true
[alias]
    df = difftool --no-prompt --tool=difftastic
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	st = status -sb
	br = branch -vv

