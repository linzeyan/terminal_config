[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	autocrlf = input
	editor = vim
	ignorecase = false
	precomposeunicode = true
	safecrlf = true
[remote "origin"]
	url = git@github.com:linzeyan/ansible
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "master"]
	remote = origin
	merge = refs/heads/master
[diff]
	algorithm = patience
[color]
	status = always
	ui = true
[alias]
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
[include]
	path = .gitconfig
#[credential]
#	helper = cache --timeout=3600
#  helper = store
#[merge]
#	algorithm = patience
#[merge "diff"]
#	algorithm = patience
